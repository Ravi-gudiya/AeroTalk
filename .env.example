# AeroTalk Environment Configuration Variables Template
# Copy this file to .env locally: cp .env.example .env

# --- Server Configurations ---
PORT=5000
JWT_SECRET=your_jwt_secret_key_here

# --- Supabase Database Configurations ---
# Retrieve these credentials from your Supabase Console: Project Settings -> API
SUPABASE_URL=https://your-supabase-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-role-api-key-here

# --- Production URL Configuration ---
# Used to configure CORS on the Express backend
FRONTEND_URL=https://aerotalk.vercel.app

# --- Frontend Configurations (Vite) ---
# Used during local development by Vite to proxy API requests to the Express backend
VITE_API_URL=http://localhost:5000
